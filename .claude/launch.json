{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "personal-page",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path');h.createServer((q,r)=>{let f=p.join('.',q.url==='/'?'/index.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end();}else{const m={'html':'text/html','css':'text/css','js':'text/javascript','mp4':'video/mp4','jpg':'image/jpeg','png':'image/png'};r.writeHead(200,{'Content-Type':m[f.split('.').pop()]||'text/plain'});r.end(d);}});}).listen(3000);"],
      "port": 3000
    }
  ]
}
